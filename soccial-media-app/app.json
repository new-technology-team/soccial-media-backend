{
  "expo": {
    "name": "ZChat",
    "slug": "zchat-mobile",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0052ce"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zchat.mobile"
    },
    "android": {
      "package": "com.zchat.mobile"
    },
    "web": {
      "bundler": "metro"
    }
  }
}
