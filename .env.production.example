NODE_ENV=production
PORT=5000

# AWS RDS MariaDB
DATABASE_URL_MARIA=mariadb://admin:CHANGE_ME_PASSWORD@CHANGE_ME_RDS_ENDPOINT:3306/zalo_app
# Enable this when your RDS instance requires SSL.
# Download the AWS RDS global bundle and place it next to this file if enabled.
# DB_SSL=true
# DB_SSL_CA_PATH=global-bundle.pem

# MongoDB Atlas
DATABASE_URL_MONGO=mongodb+srv://CHANGE_ME_USER:CHANGE_ME_PASSWORD@CHANGE_ME_CLUSTER.mongodb.net/zalo_app?retryWrites=true&w=majority

# Auth
JWT_ACCESS_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Public URLs
CORS_ORIGINS=https://CHANGE_ME_FRONTEND_DOMAIN
FRONTEND_URL=https://CHANGE_ME_FRONTEND_DOMAIN
API_PUBLIC_URL=https://CHANGE_ME_API_DOMAIN/api
GOOGLE_CALLBACK_URL=https://CHANGE_ME_API_DOMAIN/api/auth/google/callback

# AWS S3
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=CHANGE_ME_BUCKET
AWS_ACCESS_KEY_ID=CHANGE_ME_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=CHANGE_ME_SECRET_KEY

# Optional integrations
GEMINI_API_KEY=CHANGE_ME
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=CHANGE_ME_EMAIL
SMTP_PASSWORD=CHANGE_ME_APP_PASSWORD
SMTP_FROM=noreply@zzchat.com
TWILIO_ACCOUNT_SID=CHANGE_ME
TWILIO_AUTH_TOKEN=CHANGE_ME
TWILIO_FROM=CHANGE_ME
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME
