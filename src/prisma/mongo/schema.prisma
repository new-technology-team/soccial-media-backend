datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL_MONGO")
}

generator client {
  provider = "prisma-client-js"
  output   = "../../../generated/mongo"
}

model Member {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  accountId           Int
  displayName         String
  avatarUrl           String
  roleInConversation  String
  conversationId      String   @db.ObjectId

  conversation Conversation @relation(fields: [conversationId], references: [id])
}

model Conversation {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  conversationName String
  status           String
  createdAt        DateTime

  members   Member[]
  messages  Message[]
  interacts Interacts[]
}

model Message {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  messageId      Int
  conversationId String   @db.ObjectId
  content        String
  createdAt      DateTime
  fileUrl        String
  isRecalled     Boolean

  conversation Conversation @relation(fields: [conversationId], references: [id])
}

model Interacts {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  accountId      Int
  displayName    String
  avatarUrl      String
  interactType   String
  createdAt      String
  conversationId String   @db.ObjectId
  postId         String?  @db.ObjectId

  conversation Conversation @relation(fields: [conversationId], references: [id])
  post         Post?        @relation(fields: [postId], references: [id])
}

model Post {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  postId    Int
  title     String
  content   String
  createdAt DateTime

  comments  Comment[]
  interacts Interacts[]
}

model Comment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  commentId Int
  postId    String   @db.ObjectId
  content   String
  file      String
  ownerId   String   @db.ObjectId

  post  Post  @relation(fields: [postId], references: [id])
  owner Owner @relation(fields: [ownerId], references: [id])
}

model Owner {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  accountId   Int
  displayName String
  avatarUrl   String

  comments Comment[]
}

model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  notificationId Int
  userId    String
  title     String
  content   String
  link      String
  createdAt DateTime
}