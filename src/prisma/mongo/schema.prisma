datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL_MONGO")
}

generator client {
  provider = "prisma-client-js"
  output   = "../../../generated/mongo"
}

model Conversation {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  conversationName String
  status           String
  createdAt        DateTime

  members   Member[]
  interacts Interacts[]

  messages  Message[]
}

model Message {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  messageId      Int
  conversationId String   @db.ObjectId
  content        String
  createdAt      DateTime
  fileUrl        String
  isRecalled     Boolean

  conversation Conversation @relation(fields: [conversationId], references: [id])
}

model Post {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  postId    Int
  title     String
  content   String
  createdAt DateTime

  comments  Comment[]
  interacts Interacts[]
}

model Notification {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  notificationId Int
  userId         String
  title          String
  content        String
  link           String
  createdAt      DateTime
}

type Member {
  accountId          Int
  displayName        String
  avatarUrl          String
  roleInConversation String
}

type Interacts {
  accountId    Int
  displayName  String
  avatarUrl    String
  interactType String
  createdAt    String
}

type Comment {
  commentId Int
  content   String
  file      String
  owner     Owner
}

type Owner {
  accountId   Int
  displayName String
  avatarUrl   String
}